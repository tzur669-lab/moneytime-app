{
  "appId": "com.tzur669.moneytime",
  "appName": "מעקב שעות Pro",
  "webDir": "www",
  "bundledWebRuntime": false,
  "android": {
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1E3A8A",
      "showSpinner": false
    },
    "Browser": {
      "presentationStyle": "fullscreen"
    }
  }
}
